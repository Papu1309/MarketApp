<Page x:Class="MarketApp.Pages.EditCampaignPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="EditCampaignPage">
    <Grid>
        <Border Background="White" CornerRadius="10" Padding="20"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="400" Margin="20">
            <StackPanel>
                <TextBlock x:Name="txtTitle" Text="Добавление кампании" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center"/>

                <TextBlock Text="Название:" Margin="0,20,0,5"/>
                <TextBox x:Name="txtName"/>

                <TextBlock Text="Описание:" Margin="0,10,0,5"/>
                <TextBox x:Name="txtDescription" TextWrapping="Wrap" AcceptsReturn="True" Height="80"/>

                <TextBlock Text="Цена:" Margin="0,10,0,5"/>
                <TextBox x:Name="txtPrice"/>

                <TextBlock Text="Длительность (дни):" Margin="0,10,0,5"/>
                <TextBox x:Name="txtDuration"/>

                <CheckBox x:Name="chkIsActive" Content="Активна" Margin="0,10"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                    <Button Content="Сохранить" Click="BtnSave_Click" Margin="0,0,10,0" Width="100"/>
                    <Button Content="Отмена" Click="BtnCancel_Click" Width="100"/>
                </StackPanel>
                <TextBlock x:Name="txtMessage" Foreground="Red" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
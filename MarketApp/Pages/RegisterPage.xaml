<Page x:Class="MarketApp.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="RegisterPage">
    <Grid>
        <Border Background="White" CornerRadius="10" Padding="20"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="400" Margin="20">
            <StackPanel>
                <TextBlock Text="Регистрация" FontSize="24" FontWeight="Bold" 
                           Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center"/>

                <TextBlock Text="Логин:" Margin="0,20,0,5"/>
                <TextBox x:Name="txtUsername"/>

                <TextBlock Text="Пароль:" Margin="0,10,0,5"/>
                <PasswordBox x:Name="txtPassword"/>

                <TextBlock Text="Email:" Margin="0,10,0,5"/>
                <TextBox x:Name="txtEmail"/>
                <TextBlock Text="(например, user@mail.ru)" FontSize="11" Foreground="Gray" Margin="0,0,0,5"/>

                <TextBlock Text="Телефон:" Margin="0,5,0,5"/>
                <TextBox x:Name="txtPhone"/>
                <TextBlock Text="(например, +71234567890)" FontSize="11" Foreground="Gray" Margin="0,0,0,5"/>

                <Button Content="Зарегистрироваться" Click="BtnRegister_Click" Margin="0,20,0,10" Height="40"/>
                <TextBlock Text="Уже есть аккаунт? Войдите" Foreground="{StaticResource AccentColor}" 
                           HorizontalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="LoginLink_Click"/>
                <TextBlock x:Name="txtMessage" Foreground="Red" TextWrapping="Wrap" Margin="0,10"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
<Page x:Class="MarketApp.Pages.OrderDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="OrderDetailsPage" Loaded="Page_Loaded">
    <Grid>
        <Border Background="White" CornerRadius="10" Padding="20"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="600" Margin="20">
            <StackPanel>
                <TextBlock x:Name="txtOrderInfo" FontSize="20" FontWeight="Bold" 
                           Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center"/>
                <ListView x:Name="lvItems" Margin="0,20" MaxHeight="300">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Campaigns.Name}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Quantity, StringFormat={}x{0}}" Margin="10,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Price, StringFormat={}{0:C}}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <TextBlock x:Name="txtTotal" FontWeight="Bold" FontSize="16" Margin="0,10"/>
                <TextBlock x:Name="txtStatus" Margin="0,5"/>
                <TextBlock x:Name="txtPickup" TextWrapping="Wrap" Margin="0,5"/>
                <Button Content="Назад" Click="BtnBack_Click" Width="100" HorizontalAlignment="Center" Margin="0,20"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
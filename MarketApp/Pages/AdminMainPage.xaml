<Page x:Class="MarketApp.Pages.AdminMainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AdminMainPage" Loaded="Page_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <TextBlock x:Name="txtUserInfo" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Button Content="Выйти" Click="BtnLogout_Click" Padding="5"/>
        </StackPanel>
        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Кампании">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <Button Content="Добавить" Click="BtnAddCampaign_Click" Margin="0,0,5,0"/>
                        <Button Content="Редактировать" Click="BtnEditCampaign_Click" Margin="0,0,5,0"/>
                        <Button Content="Удалить" Click="BtnDeleteCampaign_Click"/>
                    </StackPanel>
                    <ListView x:Name="lvCampaigns" Grid.Row="1" Margin="5" 
                              SelectionMode="Single" IsSynchronizedWithCurrentItem="True">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" DisplayMemberBinding="{Binding Id}" Width="50"/>
                                <GridViewColumn Header="Название" DisplayMemberBinding="{Binding Name}" Width="150"/>
                                <GridViewColumn Header="Цена" DisplayMemberBinding="{Binding Price, StringFormat={}{0:C}}" Width="100"/>
                                <GridViewColumn Header="Длительность" DisplayMemberBinding="{Binding Duration}" Width="80"/>
                                <GridViewColumn Header="Активна" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsActive}" IsEnabled="False"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>
            <TabItem Header="Пользователи">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <Button Content="Сменить роль" Click="BtnChangeRole_Click" Margin="0,0,5,0"/>
                        <Button Content="Удалить" Click="BtnDeleteUser_Click"/>
                    </StackPanel>
                    <ListView x:Name="lvUsers" Grid.Row="1" Margin="5">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" DisplayMemberBinding="{Binding Id}" Width="50"/>
                                <GridViewColumn Header="Логин" DisplayMemberBinding="{Binding Username}" Width="120"/>
                                <GridViewColumn Header="Email" DisplayMemberBinding="{Binding Email}" Width="150"/>
                                <GridViewColumn Header="Телефон" DisplayMemberBinding="{Binding Phone}" Width="120"/>
                                <GridViewColumn Header="Роль" DisplayMemberBinding="{Binding Role}" Width="80"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>
            <TabItem Header="Заказы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <Button Content="Изменить статус" Click="BtnChangeOrderStatus_Click"/>
                    </StackPanel>
                    <ListView x:Name="lvOrders" Grid.Row="1" Margin="5" SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#ccc" BorderThickness="1" CornerRadius="5" Padding="10" Margin="5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding OrderDate, StringFormat={}Заказ от {0:dd.MM.yyyy HH:mm}}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Users.Username, StringFormat={}Пользователь: {0}}"/>
                                        <TextBlock Text="{Binding TotalAmount, StringFormat={}Сумма: {0:C}}"/>
                                        <TextBlock Text="{Binding Status, StringFormat={}Статус: {0}}"/>
                                        <TextBlock Text="{Binding PaymentMethod, StringFormat={}Оплата: {0}}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </TabItem>
            <TabItem Header="Статистика">
                <ScrollViewer>
                    <StackPanel Margin="20">
                        <TextBlock Text="Общая статистика" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                        <TextBlock x:Name="txtTotalOrders" FontSize="16" Margin="0,5"/>
                        <TextBlock x:Name="txtTotalRevenue" FontSize="16" Margin="0,5"/>
                        <TextBlock Text="Популярные кампании:" FontSize="16" FontWeight="Bold" Margin="0,20,0,10"/>
                        <ListBox x:Name="lstTopCampaigns" DisplayMemberPath="Display" Margin="0,5"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
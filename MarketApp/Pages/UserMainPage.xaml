<Page x:Class="MarketApp.Pages.UserMainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="UserMainPage" Loaded="Page_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <TextBlock x:Name="txtUserInfo" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Button Content="Выйти" Click="BtnLogout_Click" Padding="5"/>
        </StackPanel>
        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Каталог кампаний">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <TextBox x:Name="txtSearch" Width="200" Margin="0,0,5,0"/>
                        <Button Content="Найти" Click="BtnSearch_Click"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1">
                        <ItemsControl x:Name="lvCampaigns" Margin="5">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#ccc" BorderThickness="1" CornerRadius="5" Padding="10" Margin="5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"/>
                                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,5"/>
                                                <TextBlock Text="{Binding Price, StringFormat={}Цена: {0:C}}"/>
                                                <TextBlock Text="{Binding Duration, StringFormat={}Длительность: {0} дней}"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Добавить в корзину" 
                                                    Click="BtnAddToCart_Click" Tag="{Binding Id}" Margin="10,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            <TabItem Header="Корзина">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListView x:Name="lvCart" Margin="5">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#ccc" BorderThickness="1" CornerRadius="5" Padding="10" Margin="5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Price, StringFormat={}Цена: {0:C}}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0">
                                            <Button Content="-" Click="BtnDecreaseQuantity" Tag="{Binding CampaignId}" Width="25"/>
                                            <TextBlock Text="{Binding Quantity}" VerticalAlignment="Center" Margin="5,0"/>
                                            <Button Content="+" Click="BtnIncreaseQuantity" Tag="{Binding CampaignId}" Width="25"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Total, StringFormat={}{0:C}}" 
                                                   FontWeight="Bold" VerticalAlignment="Center" Margin="10,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                        <TextBlock x:Name="txtCartTotal" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Content="Оформить заказ" Click="BtnCheckout_Click" Padding="10,5"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Мои заказы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListView x:Name="lvOrders" Margin="5" SelectionMode="Single" IsSynchronizedWithCurrentItem="True">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#ccc" BorderThickness="1" CornerRadius="5" Padding="10" Margin="5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding OrderDate, StringFormat={}Заказ от {0:dd.MM.yyyy HH:mm}}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding TotalAmount, StringFormat={}Сумма: {0:C}}"/>
                                        <TextBlock Text="{Binding Status, StringFormat={}Статус: {0}}"/>
                                        <Button Content="Подробнее" Click="BtnOrderDetails_Click" Tag="{Binding Id}" Margin="0,5" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                        <Button Content="Обновить" Click="BtnRefreshOrders_Click" Padding="10,5"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
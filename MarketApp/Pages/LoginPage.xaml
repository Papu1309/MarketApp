<Page x:Class="MarketApp.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="LoginPage">
    <Grid>
        <Border Background="White" CornerRadius="10" Padding="20"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="400" Margin="20">
            <StackPanel>
                <TextBlock Text="Вход в систему" FontSize="24" FontWeight="Bold" 
                           Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center"/>

                <TextBlock Text="Логин:" Margin="0,20,0,5"/>
                <TextBox x:Name="txtUsername"/>

                <TextBlock Text="Пароль:" Margin="0,10,0,5"/>
                <PasswordBox x:Name="txtPassword"/>

                <Button Content="Войти" Click="BtnLogin_Click" Margin="0,20,0,10" Height="40"/>
                <TextBlock Text="Нет аккаунта? Зарегистрируйтесь" Foreground="{StaticResource AccentColor}" 
                           HorizontalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="RegisterLink_Click"/>
                <TextBlock x:Name="txtMessage" Foreground="Red" TextWrapping="Wrap" Margin="0,10"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
<Page x:Class="MarketApp.Pages.PaymentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="PaymentPage" Loaded="Page_Loaded">
    <Grid>
        <Border Background="White" CornerRadius="10" Padding="20"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="600" Margin="20">
            <StackPanel>
                <TextBlock Text="Оплата заказа" FontSize="24" FontWeight="Bold" 
                           Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center"/>
                <ListView x:Name="lvOrderItems" Margin="0,20" MaxHeight="250">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Name}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Quantity, StringFormat={}x{0}}" Margin="10,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Total, StringFormat={}{0:C}}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <TextBlock x:Name="txtTotal" FontWeight="Bold" FontSize="16" Margin="0,10"/>

                <RadioButton x:Name="rbCard" Content="Оплата картой" GroupName="Payment" 
                             Margin="0,5" Checked="RadioButton_Checked"/>
                <RadioButton x:Name="rbCash" Content="Оплата наличными" GroupName="Payment" 
                             Margin="0,5" Checked="RadioButton_Checked"/>

                <Border x:Name="cardPanel" BorderBrush="#ccc" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,10">
                    <StackPanel>
                        <TextBlock Text="Данные карты" FontWeight="Bold"/>
                        <TextBlock Text="Номер карты (16 цифр):" Margin="0,5,0,0"/>
                        <TextBox x:Name="txtCardNumber" Margin="0,5"/>
                        <WrapPanel Margin="0,5">
                            <StackPanel>
                                <TextBlock Text="ММ/ГГ:"/>
                                <TextBox x:Name="txtExpiry" Width="100"/>
                            </StackPanel>
                            <StackPanel Margin="10,0,0,0">
                                <TextBlock Text="CVV:"/>
                                <TextBox x:Name="txtCvv" Width="80"/>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Button Content="Оплатить" Click="BtnPay_Click" Height="40" Margin="0,20"/>
                <TextBlock x:Name="txtMessage" Foreground="Red" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>